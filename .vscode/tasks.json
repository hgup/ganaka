{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/apps/bench"
      },
      "presentation": {
        "group": "servers",
        "panel": "dedicated"
      },
      "runOptions": {
        "runOn": "default"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "fastapi", "dev", "main.py"],
      "options": {
        "cwd": "${workspaceFolder}/apps/backend"
      },
      "presentation": {
        "group": "servers",
        "panel": "dedicated"
      },
      "runOptions": {
        "runOn": "default"
      },
      "problemMatcher": []
    },
    {
      "label": "Generate Schema",
      "type": "shell",
      "command": "pnpx",
      "args": ["orval"],
      "options": {
        "env": {
          "NODE_OPTIONS": "--use-system-ca"
        },
        "cwd": "${workspaceFolder}/apps/bench"
      },
      "presentation": {
        "group": "servers",
        "panel": "dedicated"
      },
      "runOptions": {
        "runOn": "default"
      },
      "problemMatcher": []
    },
    {
      "label": "shadcn: add component",
      "type": "shell",
      "command": "pnpx",
      "args": ["shadcn@latest", "add", "${input:shadcnArgs}"],
      "options": {
        "cwd": "${workspaceFolder}/apps/bench",
        "env": {
          "NODE_OPTIONS": "--use-system-ca"
        },
      },
      "runOptions": {
        "runOn": "default"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false
      }
    }
  ],
  "inputs": [
    {
      "id": "shadcnArgs",
      "type": "promptString",
      "description": "Enter the shadcn component(s) to add (e.g., button card dialog)",
      "default": ""
    }
  ]
}
